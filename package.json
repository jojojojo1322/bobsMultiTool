{
  "name": "bobob-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/main"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @bobob/main",
    "build": "npm run build --workspace @bobob/main",
    "start": "npm run start --workspace @bobob/main",
    "lint": "npm run lint --workspace @bobob/main",
    "harness:registry": "node scripts/harness/validate-registry.mjs",
    "harness:blog-play-mvp": "node scripts/harness/blog-play-mvp-smoke.mjs",
    "harness:goal-audit": "node scripts/harness/blog-play-goal-audit-smoke.mjs",
    "harness:blog-play-quality": "node scripts/harness/blog-play-rendered-quality.mjs",
    "harness:play-interaction": "node scripts/harness/play-interaction-smoke.mjs",
    "harness:live-discovery": "node scripts/harness/live-discovery-smoke.mjs",
    "harness:search-discovery-registration": "node scripts/harness/search-discovery-registration-smoke.mjs",
    "harness:submitted-url-health": "node scripts/harness/submitted-url-health-smoke.mjs",
    "harness:indexing-observation": "node scripts/harness/indexing-observation-smoke.mjs",
    "harness:routes": "node scripts/harness/route-smoke.mjs",
    "harness:tools": "node scripts/harness/tool-logic-smoke.mjs",
    "harness:i18n": "node scripts/harness/i18n-smoke.mjs",
    "harness:theme": "node scripts/harness/theme-smoke.mjs",
    "harness:localization": "node scripts/harness/localization-smoke.mjs",
    "harness:search": "node scripts/harness/search-smoke.mjs",
    "harness:layout": "node scripts/harness/layout-smoke.mjs",
    "harness:visual": "node scripts/harness/visual-smoke.mjs",
    "harness:pointer-background": "node scripts/harness/pointer-background-smoke.mjs",
    "harness:agents": "node scripts/harness/agent-skills-sync.mjs",
    "harness:legacy": "node scripts/harness/legacy-main-only.mjs",
    "harness:adsense-content": "node scripts/harness/adsense-content-smoke.mjs",
    "harness:rendered-content": "node scripts/harness/rendered-content-smoke.mjs",
    "harness:seo-opportunities": "node scripts/harness/seo-opportunity-report.mjs",
    "harness:seo-measured": "BOBOB_REQUIRE_MEASURED_SEO=1 node scripts/harness/seo-opportunity-report.mjs",
    "harness:seo-opportunities:smoke": "node scripts/harness/seo-opportunity-report-smoke.mjs",
    "harness:seo-templates": "node scripts/harness/seo-export-templates.mjs",
    "harness:deployment-status": "node scripts/harness/deployment-status.mjs",
    "harness:indexnow": "node scripts/submit-indexnow.mjs --dry-run",
    "harness:websub": "node scripts/submit-websub.mjs --dry-run",
    "harness:indexing-followup": "node scripts/indexing-followup-packet.mjs --check",
    "indexnow:submit": "node scripts/submit-indexnow.mjs",
    "websub:submit": "node scripts/submit-websub.mjs",
    "seo:indexing-followup": "node scripts/indexing-followup-packet.mjs --out=reports/indexing-followup.md",
    "seo:export-packet": "BOBOB_SEO_REPORT_FORMAT=export-packet BOBOB_SEO_REPORT_OUT=reports/seo-export-packet.md node scripts/harness/seo-opportunity-report.mjs",
    "seo:report": "BOBOB_SEO_REPORT_FORMAT=markdown BOBOB_SEO_REPORT_OUT=reports/seo-opportunities.md node scripts/harness/seo-opportunity-report.mjs"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "eslint": "^9",
    "next": "^15.5.19",
    "playwright": "^1.60.0",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
